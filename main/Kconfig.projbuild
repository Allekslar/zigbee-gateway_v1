menu "Zigbee Gateway"

config ZGW_ENABLE_DEBUG_LOGS
    bool "Enable debug logs"
    default y

menu "OTA"

config ZGW_OTA_ENABLED
    bool "Enable OTA foundation"
    default y

config ZGW_OTA_BOOT_CONFIRM_ENABLED
    bool "Confirm pending OTA image after successful startup"
    depends on ZGW_OTA_ENABLED
    default y

config ZGW_OTA_BOOT_CONFIRM_TIMEOUT_MS
    int "OTA boot confirmation timeout in milliseconds"
    depends on ZGW_OTA_BOOT_CONFIRM_ENABLED
    range 1000 120000
    default 15000

choice ZGW_OTA_TLS_TRUST_MODE
    prompt "OTA HTTPS trust mode"
    depends on ZGW_OTA_ENABLED
    default ZGW_OTA_TLS_TRUST_CERT_BUNDLE

config ZGW_OTA_TLS_TRUST_CERT_BUNDLE
    bool "Use ESP x509 certificate bundle"

config ZGW_OTA_TLS_TRUST_PINNED_CA
    bool "Use pinned root CA PEM embedded in firmware"

endchoice

config ZGW_OTA_ALLOW_HTTP_URLS_FOR_TESTING
    bool "Allow plaintext http:// OTA URLs for lab/testing only"
    depends on ZGW_OTA_ENABLED
    default n
    help
        Keep disabled for production. When enabled, OTA can download over
        plaintext HTTP, which bypasses TLS trust checks and should be used
        only for controlled lab/HIL scenarios.

config ZGW_OTA_AUTO_REBOOT_ENABLED
    bool "Automatically reboot after successful OTA staging"
    depends on ZGW_OTA_ENABLED
    default y

config ZGW_OTA_REBOOT_DELAY_MS
    int "Delay before OTA-triggered reboot in milliseconds"
    depends on ZGW_OTA_AUTO_REBOOT_ENABLED
    range 500 30000
    default 3000

endmenu

menu "RCP Update"

comment "Current ESP32-C6-DevKitC builds use the native 802.15.4 radio; external RCP backends are future optional hardware support"

choice ZGW_RCP_TARGET_BACKEND
    prompt "RCP target backend"
    default ZGW_RCP_TARGET_BACKEND_NONE
    help
        Keep this set to "No target backend" for the current ESP32-C6-DevKitC
        board. Enable an external RCP backend only for a different hardware
        target that actually contains a separate radio co-processor and the
        required UART/BOOT/RESET wiring.

config ZGW_RCP_TARGET_BACKEND_NONE
    bool "No target backend"
    help
        Default and correct option for the current ESP32-C6-DevKitC target.
        Zigbee runs on the native ESP32-C6 802.15.4 radio, so there is no
        external RCP to flash or recover.

config ZGW_RCP_TARGET_BACKEND_UART
    bool "UART maintenance backend"
    help
        Optional groundwork for a future board with a separate external RCP.
        This is not part of the active production path for the current
        ESP32-C6-DevKitC target.

endchoice

config ZGW_RCP_UART_PORT
    int "RCP UART port number"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    default 1
    help
        UART port used only by an external RCP maintenance path on future
        hardware. Not used on the current ESP32-C6-DevKitC board.

config ZGW_RCP_UART_TX_GPIO
    int "RCP UART TX GPIO"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    default -1

config ZGW_RCP_UART_RX_GPIO
    int "RCP UART RX GPIO"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    default -1

config ZGW_RCP_UART_BAUDRATE
    int "RCP UART baudrate"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    range 9600 5000000
    default 460800

config ZGW_RCP_UART_BOOT_GPIO
    int "RCP BOOT mode GPIO (-1 to disable)"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    default -1

config ZGW_RCP_UART_RESET_GPIO
    int "RCP RESET GPIO (-1 to disable)"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    default -1

config ZGW_RCP_UART_BOOT_ACTIVE_HIGH
    bool "BOOT GPIO active high"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    default n

config ZGW_RCP_UART_RESET_ACTIVE_HIGH
    bool "RESET GPIO active high"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    default n

config ZGW_RCP_UART_ENTER_UPDATE_DELAY_MS
    int "Delay after entering update mode (ms)"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    range 0 1000
    default 50

config ZGW_RCP_UART_RESET_PULSE_MS
    int "Reset pulse width (ms)"
    depends on ZGW_RCP_TARGET_BACKEND_UART
    range 1 1000
    default 20

endmenu

config ZGW_MQTT_TRANSPORT_ENABLED
    bool "Enable MQTT transport adapter"
    default n

config ZGW_MQTT_BROKER_URI
    string "MQTT broker URI"
    depends on ZGW_MQTT_TRANSPORT_ENABLED
    default "mqtt://homeassistant.local:1883"

config ZGW_MQTT_CLIENT_ID
    string "MQTT client id"
    depends on ZGW_MQTT_TRANSPORT_ENABLED
    default "zigbee-gateway"

config ZGW_MQTT_USERNAME
    string "MQTT username"
    depends on ZGW_MQTT_TRANSPORT_ENABLED
    default ""

config ZGW_MQTT_PASSWORD
    string "MQTT password"
    depends on ZGW_MQTT_TRANSPORT_ENABLED
    default ""

config ZGW_MQTT_KEEPALIVE_SEC
    int "MQTT keepalive seconds"
    depends on ZGW_MQTT_TRANSPORT_ENABLED
    range 15 300
    default 120

config ZGW_MQTT_NETWORK_TIMEOUT_MS
    int "MQTT network timeout (ms)"
    depends on ZGW_MQTT_TRANSPORT_ENABLED
    range 1000 60000
    default 30000

config ZGW_MQTT_RECONNECT_TIMEOUT_MS
    int "MQTT reconnect backoff (ms)"
    depends on ZGW_MQTT_TRANSPORT_ENABLED
    range 1000 120000
    default 45000

config ZGW_MQTT_RESUME_AFTER_OTA_DELAY_MS
    int "MQTT resume delay after OTA failure (ms)"
    depends on ZGW_MQTT_TRANSPORT_ENABLED
    range 0 30000
    default 2000

endmenu
